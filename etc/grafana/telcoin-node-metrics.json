{
  "annotations": {
    "list": []
  },
  "description": "Telcoin Network node metrics: consensus, execution, networking, batches, and security signals. Scraped from the node's --metrics endpoint; node/chain labels are attached externally by the collector (Alloy).",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Node Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Canonical Height",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_engine_canonical_height",
          "refId": "A",
          "legendFormat": "height"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Latest canonical block height produced by the engine."
    },
    {
      "id": 3,
      "type": "state-timeline",
      "title": "Node Mode",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_node_mode == 1",
          "refId": "A",
          "legendFormat": "{{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "One-hot node mode: cvv_active / cvv_inactive / observer."
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Consensus Sync Distance",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_node_consensus_sync_distance",
          "refId": "A",
          "legendFormat": "behind by"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Gossip consensus height minus locally executed height. Persistently growing = falling behind."
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queued Consensus Outputs",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_engine_queued_outputs",
          "refId": "A",
          "legendFormat": "queued"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {},
      "description": "Backlog of consensus outputs awaiting execution. Growth means execution is falling behind consensus."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Current Epoch",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_epoch_current",
          "refId": "A",
          "legendFormat": "epoch"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Time to Epoch Boundary",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_epoch_boundary_timestamp_seconds - time()",
          "refId": "A",
          "legendFormat": "remaining"
