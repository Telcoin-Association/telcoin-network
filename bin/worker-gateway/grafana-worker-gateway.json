{
  "annotations": {
    "list": []
  },
  "description": "Telcoin Network worker gateway metrics: traffic, rejections, latency, upstream readiness, and process resource use. Scraped from the gateway's --metrics endpoint; node/instance labels are attached externally by the collector.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (outcome) (rate(tn_worker_gateway_requests_total[5m]))",
          "refId": "A",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {},
      "description": "Proxied requests per second split by terminal outcome (forwarded vs rejected)."
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "In-flight requests (autoscaling signal)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_worker_gateway_inflight_requests",
          "refId": "A",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {},
      "description": "Concurrent proxied requests in flight. This is the gauge the HorizontalPodAutoscaler targets."
    },
    {
      "id": 4,
      "type": "row",
      "title": "Errors",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rejections by reason",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (reason) (rate(tn_worker_gateway_rejections_total[5m]))",
          "refId": "A",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "fillOpacity": 30
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {},
      "description": "Rejected requests per second by reason (no_upstream_ready, upstream_unreachable, upstream_timeout, request_too_large, loop_detected, request_timeout, rate_limited, invalid_transaction, unsupported_transaction_type, unreadable_body)."
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Reject ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(tn_worker_gateway_requests_total{outcome=\"rejected\"}[5m])) / clamp_min(sum(rate(tn_worker_gateway_requests_total[5m])), 1)",
          "refId": "A",
          "legendFormat": "reject ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "description": "Fraction of proxied requests rejected. Denominator is clamped to >= 1 req/s so the ratio reads 0 (not NaN) when there is no traffic."
    },
    {
      "id": 7,
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request duration p50/p90/p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(tn_worker_gateway_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.9, sum by (le) (rate(tn_worker_gateway_request_duration_seconds_bucket[5m])))",
          "refId": "B",
          "legendFormat": "p90"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(tn_worker_gateway_request_duration_seconds_bucket[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "description": "End-to-end proxied-request latency quantiles derived from the request duration histogram."
    },
    {
      "id": 9,
      "type": "row",
      "title": "Upstreams",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      }
    },
    {
      "id": 10,
      "type": "state-timeline",
      "title": "Upstream readiness",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "tn_worker_gateway_upstream_ready",
          "refId": "A",
          "legendFormat": "worker {{worker_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {},
      "description": "Per-worker upstream readiness (1 ready / 0 not ready). No worker at 1 means /ready returns 503 and requests reject with no_upstream_ready."
    },
    {
      "id": 11,
      "type": "row",
      "title": "Process",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "CPU",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 37
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(reth_process_cpu_seconds_total[5m])",
          "refId": "A",
          "legendFormat": "cpu cores"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {},
      "description": "CPU seconds consumed per second (approximately cores in use). From the shared recorder's process metrics."
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Resident memory",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 37
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "reth_process_resident_memory_bytes",
          "refId": "A",
          "legendFormat": "rss"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {},
      "description": "Resident set size of the gateway process. From the shared recorder's process metrics."
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "telcoin",
    "worker-gateway"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Telcoin Worker Gateway",
  "uid": "telcoin-worker-gateway",
  "version": 1
}
